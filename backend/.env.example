# ============================================
# advance.al Backend — Environment Configuration
# ============================================
# Copy to .env and fill in real values before running.
# CRITICAL: Never commit .env to version control.

# Database Configuration
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0

# Server Configuration
PORT=3001
NODE_ENV=development

# JWT Configuration — CRITICAL: Must be unique, random strings in production
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_BYTE_HEX_STRING
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_BYTE_HEX_STRING
JWT_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URL (for CORS, email links, password reset URLs)
FRONTEND_URL=http://localhost:5173

# Cloudinary Configuration (image/file uploads — required for production)
CLOUDINARY_CLOUD_NAME=your-cloudinary-name
CLOUDINARY_API_KEY=your-cloudinary-key
CLOUDINARY_API_SECRET=your-cloudinary-secret

# Email — Resend (primary, recommended)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@advance.al
EMAIL_TEST_MODE=false

# Email — SMTP (fallback, optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password

# Admin Configuration
ADMIN_EMAIL=admin@advance.al
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Security
BCRYPT_SALT_ROUNDS=12

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# OpenAI (embeddings + CV generation)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-2024-08-06
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Upstash Redis (optional — caching disabled if not set)
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token

# Sentry Error Tracking (optional — disabled if not set)
SENTRY_DSN=
SENTRY_ENABLED=false

# Alert Emails (optional — for embedding worker failures)
ALERT_EMAIL_ENABLED=false
ALERT_EMAIL_TO=ops@advance.al

# Twilio SMS (optional — not required for initial launch)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE=

# Embedding Worker Tuning (defaults are fine for most cases)
# EMBEDDING_WORKER_ENABLED=true
# EMBEDDING_WORKER_INTERVAL=5000
# EMBEDDING_BATCH_SIZE=500
# EMBEDDING_MAX_CONCURRENT=3
# SIMILARITY_TOP_N=10
# SIMILARITY_MIN_SCORE=0.7
