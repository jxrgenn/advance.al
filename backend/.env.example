# ============================================
# advance.al Backend — Environment Configuration
# ============================================
# Copy to .env and fill in real values before running.
# CRITICAL: Never commit .env to version control.

# Database Configuration
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0

# Server Configuration
PORT=3001
NODE_ENV=development

# JWT Configuration — CRITICAL: Must be unique, random strings in production
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_BYTE_HEX_STRING
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_BYTE_HEX_STRING
JWT_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URL (for CORS, email links, password reset URLs)
FRONTEND_URL=http://localhost:5173

# Cloudinary Configuration (image/file uploads — required for production)
CLOUDINARY_CLOUD_NAME=your-cloudinary-name
CLOUDINARY_API_KEY=your-cloudinary-key
CLOUDINARY_API_SECRET=your-cloudinary-secret

# Email — Resend (primary, recommended)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@advance.al
EMAIL_TEST_MODE=false

# Email — SMTP (fallback, optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password

# Admin Configuration
ADMIN_EMAIL=admin@advance.al
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Security
BCRYPT_SALT_ROUNDS=12

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# OpenAI (embeddings + CV generation)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-2024-08-06
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Upstash Redis (optional — caching disabled if not set)
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token

# Sentry Error Tracking (optional — disabled if not set)
SENTRY_DSN=
SENTRY_ENABLED=false

# Alert Emails (optional — for embedding worker failures)
ALERT_EMAIL_ENABLED=false
ALERT_EMAIL_TO=ops@advance.al

# Twilio SMS (optional — not required for initial launch)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE=

# Discord Webhooks (one URL per channel — leave empty to disable that channel)
# Create in Discord: Channel → Edit → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_SIGNUPS=
DISCORD_WEBHOOK_PAYMENTS=
DISCORD_WEBHOOK_JOBS=
DISCORD_WEBHOOK_APPLICATIONS=
DISCORD_WEBHOOK_REPORTS=
DISCORD_WEBHOOK_ERRORS=
DISCORD_WEBHOOK_CTA=
DISCORD_WEBHOOK_DIGEST=

# Discord tuning (defaults shown — only override if you know why)
DISCORD_RATE_LIMIT_PER_MIN=25
DISCORD_DEDUP_WINDOW_MS=30000
DISCORD_ERRORS_PER_MIN=10
DISCORD_DIGEST_HOUR_UTC=7
DISCORD_DIGEST_LOOKBACK_H=24
# DISCORD_VERBOSE=true   # include raw IP + full UA — debug only, privacy-sensitive

# Embedding Worker Tuning (defaults are fine for most cases)
# EMBEDDING_WORKER_ENABLED=true
# EMBEDDING_WORKER_INTERVAL=5000
# EMBEDDING_BATCH_SIZE=500
# EMBEDDING_MAX_CONCURRENT=3
# SIMILARITY_TOP_N=10
# SIMILARITY_MIN_SCORE=0.7

# Debug Logging (NEVER enable in production — may leak sensitive data)
# DEBUG_EMBEDDINGS=false
# DEBUG_WORKER=false
# DEBUG_QUEUE=false

# Payments (mock mode — returns 503 in production)
# ENABLE_MOCK_PAYMENTS=false

# Paysera (Albanian payment gateway; Stripe not available in Albania)
# In dev with these UNSET + NODE_ENV=development, the /payment flow falls
# back to an auto-accept fake-success route so post-payment UI is QA-able
# without real keys. In production with these UNSET, /api/payments/paysera/initiate
# returns 503 with an admin-must-configure message.
# PAYSERA_PROJECT_ID=
# PAYSERA_SIGN_PASSWORD=
# PAYSERA_TEST=true     # set to true to use Paysera sandbox; false for live
# PAYSERA_ALLOW_FAKE_SUCCESS=true  # DEV ONLY — bypasses the prod-503 gate
                                   # when keys are missing, returns
                                   # /payment/fake-success so the UI flow is
                                   # testable. NEVER set in production.
# FRONTEND_URL=         # override default frontend host (used for accept/cancel URLs)
# BACKEND_URL=          # override default backend host (used for callback URL)

# Payment-reminder follow-up worker — emails employers whose jobs have been in
# pending_payment for >threshold without paying. Sends ONCE per job (idempotent).
# PAYMENT_REMINDER_AFTER_HOURS=24       # threshold before first reminder fires
# PAYMENT_REMINDER_INTERVAL_MS=3600000  # how often the worker scans (default 1h)

# Logging
# LOG_LEVEL=info

# IndexNow — instant search-engine indexing (Bing, Yandex, Naver, Seznam).
# Key must match the file at https://advance.al/<KEY>.txt
# (we ship that file in frontend/public/). Default ships with prod key baked
# into the code; only override here if rotating the key.
# INDEXNOW_KEY=ec873bbed088d12068b5a827e0f6ddb5
# INDEXNOW_HOST=advance.al
# INDEXNOW_FORCE=1   # set in dev to actually ping (default: only pings when NODE_ENV=production)
