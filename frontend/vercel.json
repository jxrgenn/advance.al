        }
      ]
    },
    {
      "source": "/((?!api/|assets/).+)",
      "destination": "/api/seo",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*([gG][oO][oO][gG][lL][eE][bB][oO][tT]|[bB][iI][nN][gG][bB][oO][tT]|[dD][uU][cC][kK][dD][uU][cC][kK][bB][oO][tT]|[sS][lL][uU][rR][pP]|[bB][aA][iI][dD][uU][sS][pP][iI][dD][eE][rR]|[yY][aA][nN][dD][eE][xX][bB][oO][tT]|[gG][pP][tT][bB][oO][tT]|[cC][hH][aA][tT][gG][pP][tT]-[uU][sS][eE][rR]|[oO][aA][iI]-[sS][eE][aA][rR][cC][hH][bB][oO][tT]|[cC][lL][aA][uU][dD][eE][bB][oO][tT]|[cC][lL][aA][uU][dD][eE]-[uU][sS][eE][rR]|[cC][lL][aA][uU][dD][eE]-[sS][eE][aA][rR][cC][hH][bB][oO][tT]|[cC][lL][aA][uU][dD][eE]-[wW][eE][bB]|[aA][nN][tT][hH][rR][oO][pP][iI][cC]-[aA][iI]|[pP][eE][rR][pP][lL][eE][xX][iI][tT][yY][bB][oO][tT]|[pP][eE][rR][pP][lL][eE][xX][iI][tT][yY]-[uU][sS][eE][rR]|[gG][oO][oO][gG][lL][eE]-[eE][xX][tT][eE][nN][dD][eE][dD]|[aA][pP][pP][lL][eE][bB][oO][tT]-[eE][xX][tT][eE][nN][dD][eE][dD]|[cC][cC][bB][oO][tT]|[bB][yY][tT][eE][sS][pP][iI][dD][eE][rR]|[aA][mM][aA][zZ][oO][nN][bB][oO][tT]|[cC][oO][hH][eE][rR][eE]-[aA][iI]|[dD][iI][fF][fF][bB][oO][tT]|[aA][iI]2[bB][oO][tT]|[mM][iI][sS][tT][rR][aA][lL][aA][iI]-[uU][sS][eE][rR]|[mM][eE][tT][aA]-[eE][xX][tT][eE][rR][nN][aA][lL][aA][gG][eE][nN][tT]|[mM][eE][tT][aA]-[eE][xX][tT][eE][rR][nN][aA][lL][fF][eE][tT][cC][hH][eE][rR]|[fF][aA][cC][eE][bB][oO][oO][kK][bB][oO][tT]|[fF][aA][cC][eE][bB][oO][oO][kK][eE][xX][tT][eE][rR][nN][aA][lL][hH][iI][tT]|[tT][wW][iI][tT][tT][eE][rR][bB][oO][tT]|[lL][iI][nN][kK][eE][dD][iI][nN][bB][oO][tT]|[wW][hH][aA][tT][sS][aA][pP][pP]|[tT][eE][lL][eE][gG][rR][aA][mM][bB][oO][tT]|[sS][lL][aA][cC][kK][bB][oO][tT]|[dD][iI][sS][cC][oO][rR][dD][bB][oO][tT]).*"
        }
      ]
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=(), interest-cohort=()"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' https://*.sentry.io https://browser.sentry-cdn.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: blob: https://res.cloudinary.com https://*.cloudinary.com; connect-src 'self' https://advance-al.onrender.com https://*.sentry.io https://*.ingest.de.sentry.io https://*.ingest.sentry.io; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'; upgrade-insecure-requests"
        },
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        },
        {
          "key": "X-DNS-Prefetch-Control",
          "value": "on"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
